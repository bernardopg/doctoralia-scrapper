# API Configuration
API_KEY=your-secure-api-key-here
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret

# Dashboard Authentication (optional, but recommended outside local bootstrap)
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_PASSWORD_HASH=
DASHBOARD_SESSION_SECRET=
DASHBOARD_SESSION_TTL_MINUTES=480

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# PostgreSQL Configuration
# Senha obrigatória do Postgres em produção (gere com `openssl rand -hex 24`).
DATABASE_URL=postgresql+asyncpg://doctoralia:change-this-postgres-password@db:5432/doctoralia
POSTGRES_USER=doctoralia
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=doctoralia
POSTGRES_HOST_PORT=5432

# Selenium Configuration
SELENIUM_REMOTE_URL=http://selenium:4444/wd/hub

# Telegram Configuration (optional)
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# OpenAI Configuration (optional, for response generation)
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# n8n Configuration
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-password
N8N_ENCRYPTION_KEY=change-with-64-hex-chars
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
GENERIC_TIMEZONE=America/Sao_Paulo

# Application Settings
LOG_LEVEL=INFO
MASK_PII=true

# Production reverse proxy (docker-compose.prod.yml) — Caddy + TLS
# Domínio do dashboard+API. Em produção use o domínio real (ex.: app.exemplo.com).
APP_DOMAIN=localhost
# Domínio do editor n8n. Em produção use um subdomínio real (ex.: n8n.exemplo.com).
N8N_DOMAIN=n8n.localhost
# Senha obrigatória do Redis no overlay de produção (gere com `openssl rand -hex 24`).
REDIS_PASSWORD=change-this-redis-password
# Portas do host para o Caddy. Padrão 80/443; altere se já estiverem ocupadas.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
